{
  "name": "attendance-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "api": "json-server --watch db.json --port 3001",
    "dev:all": "concurrently --kill-others-on-fail \"npm run dev\" \"npm run api\"",
    "test": "jest --watchAll=false --coverage",
    "test:watch": "jest --watch",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "pw:test": "playwright test",
    "cy:run:ci": "start-server-and-test dev:all http://localhost:3000 cy:run",
    "pw:test:ci": "start-server-and-test dev:all http://localhost:3000 pw:test",
    "e2e:all": "start-server-and-test dev:all http://localhost:3000 \"npm run cy:run && npm run pw:test\"",
    "test:push": "jest --coverage && npm run cy:run:ci && npm run pw:test:ci",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.5",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/recharts": "^1.8.29",
    "concurrently": "^9.2.1",
    "cypress": "^15.14.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "json-server": "^1.0.0-beta.15",
    "msw": "^2.13.6",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}