#!/bin/sh
# .husky/pre-push

echo ' Running test suite before push...'

# Step 1 — Jest unit tests
echo '→ Running Jest unit tests...'
npm test -- --coverage
if [ $? -ne 0 ]; then
  echo ' Jest tests failed or coverage threshold not met. Push blocked.'
  exit 1
fi

# Step 2 — All E2E tests (single server lifecycle)
echo '→ Running Cypress + Playwright E2E tests...'
npm run e2e:all
if [ $? -ne 0 ]; then
  echo ' E2E tests failed. Push blocked.'
  exit 1
fi

echo ' All tests passed. Pushing...'